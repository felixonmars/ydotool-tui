@dataclass(frozen=True)
class Action:
    label: str
    detail: str
    run: Callable[["Controller"], None]


@dataclass(frozen=True)
class CommandJob:
    display: str
    command: list[str]
    env: dict[str, str] | None


class Controller:
    def __init__(
        self,
        ssh_target: str | None,
        ydotool: str,
        dry_run: bool,
        socket_path: str | None,
        key_delay: int,
    ) -> None:
        self.ssh_target = ssh_target
        self.ydotool = ydotool
        self.dry_run = dry_run
        self.socket_path = socket_path
        self.key_delay = key_delay
        self.last_command = ""
        self.last_status = "Ready"
        self.pending: deque[CommandJob] = deque()
        self.current: subprocess.Popen[str] | None = None

    def key(self, names: Sequence[str]) -> None:
        events = [f"{KEYS[name]}:1" for name in names]
        events.extend(f"{KEYS[name]}:0" for name in reversed(names))
        self.run(["key", "--key-delay", str(self.key_delay), *events])

    def type_text(self, text: str) -> None:
        if text:
            self.run(["type", text])

    def click(self, button: str, repeat: int = 1) -> None:
        command = ["click"]
        if repeat != 1:
            command.extend(["--repeat", str(repeat)])
        command.append(BUTTONS[button])
        self.run(command)

    def move(self, dx: int, dy: int) -> None:
        self.run(["mousemove", "--", str(dx), str(dy)])

    def wheel(self, x: int, y: int) -> None:
        self.run(["mousemove", "--wheel", "--", str(x), str(y)])

    def run(self, ydotool_args: Sequence[str]) -> None:
        command = [self.ydotool, *ydotool_args]
        env_prefix: list[str] = []
        if self.socket_path:
            env_prefix = [f"YDOTOOL_SOCKET={self.socket_path}"]

        display_command = " ".join(shlex.quote(part) for part in [*env_prefix, *command])
        local_command = command
        env = os.environ.copy()
        if self.socket_path:
            env["YDOTOOL_SOCKET"] = self.socket_path
        job_env: dict[str, str] | None = env

        if self.ssh_target:
            remote = " ".join(shlex.quote(part) for part in [*env_prefix, *command])
            local_command = ["ssh", self.ssh_target, remote]
            display_command = " ".join(shlex.quote(part) for part in local_command)
            job_env = None

        self.last_command = display_command
        if self.dry_run:
            self.last_status = "Dry run"
            return

        self.pending.append(CommandJob(display_command, local_command, job_env))
        self.last_status = f"Queued ({len(self.pending)})"

    def tick(self) -> None:
        if self.current is not None:
            if self.current.poll() is None:
                return
            self.finish_current()

        if not self.pending:
            return

        job = self.pending.popleft()
        self.last_command = job.display
        try:
            self.current = subprocess.Popen(
                job.command,
                stdin=subprocess.DEVNULL,
                env=job.env,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
            )
        except FileNotFoundError as exc:
            self.last_status = f"Command not found: {exc.filename}"
            self.current = None
            return

        suffix = f", {len(self.pending)} queued" if self.pending else ""
        self.last_status = f"Running{suffix}"

    def finish_current(self) -> None:
        if self.current is None:
            return

        stdout, stderr = self.current.communicate()
        output = (stderr or stdout).strip()
        if self.current.returncode == 0:
            self.last_status = "Sent"
        elif output:
            self.last_status = output.splitlines()[-1][:160]
        else:
            self.last_status = f"Failed with exit code {self.current.returncode}"
        self.current = None

    def close(self) -> None:
        if self.current is not None and self.current.poll() is None:
            self.current.terminate()
            try:
                self.current.wait(timeout=1)
            except subprocess.TimeoutExpired:
                self.current.kill()
                self.current.wait()
        self.current = None
        self.pending.clear()


def press(names: Sequence[str]) -> Callable[[Controller], None]:
    return lambda controller: controller.key(names)


def click(button: str, repeat: int = 1) -> Callable[[Controller], None]:
    return lambda controller: controller.click(button, repeat)


